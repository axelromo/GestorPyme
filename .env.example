# =============================================================================
# GestorPyme — Variables de entorno
# Copia este archivo a .env y completa los valores.
# NUNCA subas .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase / PostgreSQL
# -----------------------------------------------------------------------------

# Pooler en modo transacción (puerto 6543, con ?pgbouncer=true)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Conexión directa o session pooler (puerto 5432) — usada por migraciones Prisma
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# -----------------------------------------------------------------------------
# Clerk — https://dashboard.clerk.com → API Keys
# -----------------------------------------------------------------------------

PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Rutas de autenticación
PUBLIC_CLERK_SIGN_IN_URL=/sign-in
PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# -----------------------------------------------------------------------------
# Resend — https://resend.com/api-keys
# -----------------------------------------------------------------------------

RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Remitente opcional. Si no se define, se usa el correo de la configuración de empresa.
# RESEND_FROM_EMAIL="Mi Empresa <noreply@tudominio.com>"
